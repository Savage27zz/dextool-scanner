# ──────────────────────────────────────
# Telegram Configuration
# ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ──────────────────────────────────────
# Wallet Configuration
# ──────────────────────────────────────
# Base58-encoded Solana private key, or JSON byte array [1,2,3,...]
PRIVATE_KEY=your_base58_private_key

# ──────────────────────────────────────
# RPC Endpoints
# ──────────────────────────────────────
# Solana (primary) — use Helius/QuickNode for better reliability
RPC_URL_SOL=https://api.mainnet-beta.solana.com

# EVM chains (optional, only needed if CHAIN=ETH or CHAIN=BSC)
RPC_URL_ETH=https://mainnet.infura.io/v3/YOUR_KEY
RPC_URL_BSC=https://bsc-dataseed1.binance.org

# ──────────────────────────────────────
# DexTools API
# ──────────────────────────────────────
DEXTOOLS_API_KEY=your_dextools_api_key
DEXTOOLS_PLAN=trial

# ──────────────────────────────────────
# Chain Selection
# ──────────────────────────────────────
# SOL (default) | ETH | BSC
CHAIN=SOL

# ──────────────────────────────────────
# Trading Configuration
# ──────────────────────────────────────
BUY_PERCENT=50
TAKE_PROFIT=20
SLIPPAGE=15

# ──────────────────────────────────────
# Filter Configuration
# ──────────────────────────────────────
MIN_LIQUIDITY=5000
MAX_MCAP=500000
MIN_MCAP=10000

# ──────────────────────────────────────
# Intervals (seconds)
# ──────────────────────────────────────
SCAN_INTERVAL=60
MONITOR_INTERVAL=30
